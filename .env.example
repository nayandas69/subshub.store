# ==============================================================================
# SubsHub.store - Environment Setup Guide
# ==============================================================================
# Instructions:
# 1. Create a new file named `.env.local` in this folder.
# 2. Copy all the content below into that new `.env.local` file.
# 3. Fill in the values using the guide below.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DATABASE (MongoDB Atlas)
# ------------------------------------------------------------------------------
# HOW TO GET:
# 1. Go to https://www.mongodb.com and sign up for a free "M0" Cluster.
# 2. Create a Database User and save the password.
# 3. Go to "Network Access" and click "Add IP Address" -> "Allow Access from Anywhere".
# 4. Click "Connect" -> "Drivers" -> Copy the Connection String.
# 5. Replace <password> in the string with your Database User password.
MONGODB_URI="mongodb+srv://username:password@cluster.mongodb.net/subshub"

# ------------------------------------------------------------------------------
# 2. ADMIN LOGIN (Your Choice)
# ------------------------------------------------------------------------------
# HOW TO GET:
# You choose these yourself! 
# When you first log in at /admin/login with these exact details, 
# the system will automatically create your admin account in the database.
DEFAULT_ADMIN_EMAIL="admin@subshub.store"
DEFAULT_ADMIN_PASSWORD="ChooseAStrongPasswordHere"

# ------------------------------------------------------------------------------
# 3. SECURITY (Session Secret)
# ------------------------------------------------------------------------------
# HOW TO GET:
# This is used to encrypt your login cookies. It should be a long random string.
# You can generate one by typing this in your terminal:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="generate-a-long-random-string-here"

# ------------------------------------------------------------------------------
# 4. BRANDING & WHATSAPP
# ------------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_NAME: The name of your store shown in the header.
# NEXT_PUBLIC_WHATSAPP_NUMBER: Your phone number WITH country code, but NO spaces or +.
#                              Example for Bangladesh: 8801700000000
# NEXT_PUBLIC_SITE_URL: The URL where your site is hosted (e.g. https://subshub.store)
NEXT_PUBLIC_SITE_NAME="SubsHub"
NEXT_PUBLIC_WHATSAPP_NUMBER="8801XXXXXXXXX"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
